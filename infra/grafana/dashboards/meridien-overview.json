          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "Agent Turn Latency (p95)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(meridien_agent_turn_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
