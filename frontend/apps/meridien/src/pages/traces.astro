---
import Layout from '../layouts/Layout.astro';
import TraceGrid from '../components/traces/TraceGrid.tsx';
---

<Layout title="Meridien Merchant Portal - System Traces">
    <!-- Topbar -->
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 border-b border-circuit-grey pb-6">
        <div>
            <h2 class="text-3xl font-bold tracking-tight text-on-surface font-heading flex items-center gap-3">
                <svg class="w-7 h-7 text-logic-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                System Traces
            </h2>
            <p class="text-on-surface-variant mt-2 text-sm">Deep AI observability. Inspect every thought and tool call made by Synapse AI.</p>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 w-full md:w-auto">
            <!-- Search -->
            <div class="relative group w-full sm:w-auto">
                <svg class="w-4 h-4 text-logic-teal absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="text" placeholder="Search by trace ID, channel, or prompt..." class="w-full sm:w-80 bg-surface-container-lowest border border-circuit-grey rounded-full py-2.5 pl-10 pr-5 text-sm text-on-surface focus:outline-none focus:border-logic-teal focus:shadow-[0_0_10px_rgba(194,101,42,0.2)] transition-all placeholder:text-terminal-dim">
            </div>
            <button class="w-full sm:w-auto bg-logic-teal hover:bg-logic-teal/90 text-surface-container-lowest px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-lg shadow-logic-teal/20 whitespace-nowrap">
                Export Logs
            </button>
        </div>
    </header>

    <div class="w-full">
        <TraceGrid client:load />
    </div>
</Layout>
