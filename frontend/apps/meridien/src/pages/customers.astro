---
import Layout from '../layouts/Layout.astro';
import CustomerGrid from '../components/customers/CustomerGrid';
---

<Layout title="Meridien Merchant Portal - Customers">
    <!-- Topbar -->
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 border-b border-circuit-grey pb-6">
        <div>
            <h2 class="text-3xl font-bold tracking-tight text-on-surface font-heading flex items-center gap-3">
                <svg class="w-7 h-7 text-logic-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                Customer Profiles
            </h2>
            <p class="text-on-surface-variant mt-2 text-sm">Unified CRM powered by Synapse AI.</p>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 w-full md:w-auto">
            <!-- Search -->
            <div class="relative group w-full sm:w-auto">
                <svg class="w-4 h-4 text-logic-teal absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="text" placeholder="Search by name, summary, or channel..." class="w-full sm:w-80 bg-surface-container-lowest border border-circuit-grey rounded-full py-2.5 pl-10 pr-5 text-sm text-on-surface focus:outline-none focus:border-logic-teal focus:shadow-[0_0_10px_rgba(194,101,42,0.2)] transition-all placeholder:text-terminal-dim">
            </div>
            <button class="w-full sm:w-auto bg-logic-teal hover:bg-logic-teal/90 text-surface-container-lowest px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-lg shadow-logic-teal/20 whitespace-nowrap">
                Export Data
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <div class="grid grid-cols-1 gap-6">
        <CustomerGrid client:load />
    </div>
</Layout>
