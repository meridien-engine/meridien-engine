---
import Layout from '../layouts/Layout.astro';
import SettingsPanel from '../components/settings/SettingsPanel.tsx';
---

<Layout title="Meridien Merchant Portal - Settings">
    <!-- Topbar -->
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 border-b border-circuit-grey pb-6">
        <div>
            <h2 class="text-3xl font-bold tracking-tight text-on-surface font-heading flex items-center gap-3">
                <svg class="w-7 h-7 text-logic-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Settings & Integrations
            </h2>
            <p class="text-on-surface-variant mt-2 text-sm">Manage your business profile, API keys, and Synapse AI preferences.</p>
        </div>
        <div class="flex items-center gap-4">
            <button class="bg-surface-container-high hover:bg-surface-container-highest text-on-surface border border-circuit-grey px-5 py-2.5 rounded-lg text-sm font-medium transition-colors whitespace-nowrap">
                Discard Changes
            </button>
            <button class="bg-logic-teal hover:bg-logic-teal/90 text-surface-container-lowest px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-lg shadow-logic-teal/20 whitespace-nowrap">
                Save Settings
            </button>
        </div>
    </header>

    <div class="w-full">
        <SettingsPanel client:load />
    </div>
</Layout>
