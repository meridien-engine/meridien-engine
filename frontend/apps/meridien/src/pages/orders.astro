---
import Layout from '../layouts/Layout.astro';
import DataGrid from '../components/orders/DataGrid';
---

<Layout title="Meridien Merchant Portal - Orders">
    <header class="flex items-center justify-between mb-8 border-b border-circuit-grey pb-6">
        <div>
            <h2 class="text-3xl font-bold tracking-tight text-on-surface font-heading flex items-center gap-3">
                Orders
            </h2>
            <p class="text-on-surface-variant mt-2 text-sm">Manage, filter, and review customer orders and AI interceptions.</p>
        </div>
    </header>

    <div class="w-full">
        <DataGrid client:load />
    </div>
</Layout>
