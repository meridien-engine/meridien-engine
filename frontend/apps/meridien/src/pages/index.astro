---
import Layout from '../layouts/Layout.astro';
import LiveFeed from '../components/dashboard/LiveFeed';
import RevenueChart from '../components/dashboard/RevenueChart';
import OverviewMetrics from '../components/dashboard/OverviewMetrics';
---

<Layout title="Meridien Merchant Portal - Dashboard">
    <!-- Topbar -->
    <header class="flex items-center justify-between mb-10 border-b border-circuit-grey pb-6">
        <div>
            <h2 class="text-3xl font-bold tracking-tight text-on-surface font-heading flex items-center gap-3">
                <span class="w-3 h-3 bg-logic-teal inline-block rounded-full"></span>
                System Overview
            </h2>
            <p class="text-on-surface-variant mt-2 text-sm">Meridien Analytics Engine is running smoothly.</p>
        </div>
        <div class="flex items-center gap-6">
            <!-- Active Channels Badge -->
            <span class="flex items-center gap-2 text-[11px] font-medium border border-logic-teal/30 bg-logic-teal/5 px-3 py-1.5 text-logic-teal rounded-full">
                Active Channels: WhatsApp, Messenger
            </span>
            <!-- Search -->
            <div class="relative group">
                <svg class="w-4 h-4 text-logic-teal absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="text" placeholder="Search records..." class="bg-surface-container-lowest border border-circuit-grey rounded-full py-2.5 pl-10 pr-5 text-sm text-on-surface focus:outline-none focus:border-logic-teal focus:shadow-[0_0_10px_rgba(194,101,42,0.2)] w-72 transition-all placeholder:text-terminal-dim">
            </div>
        </div>
    </header>

    <!-- Dashboard Content -->
    <div class="grid grid-cols-12 gap-6">
        
        <!-- Metrics Row -->
        <OverviewMetrics client:load />

        <!-- Main Chart & Recent Activity -->
        <div class="col-span-8 bg-surface-container-low border border-circuit-grey rounded-2xl p-6 h-[400px] relative overflow-hidden group hover:border-logic-teal transition-colors">
            <RevenueChart client:load />
        </div>

        <!-- Recent Activity Feed -->
        <div class="col-span-4 bg-surface-container-low border border-circuit-grey rounded-2xl p-6 h-[400px] flex flex-col relative overflow-hidden group hover:border-logic-teal transition-colors">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-surface-container-low z-10 pointer-events-none"></div>
            
            <LiveFeed client:load />
            
        </div>

    </div>
</Layout>
