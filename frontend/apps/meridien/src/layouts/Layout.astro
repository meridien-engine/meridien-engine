---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" dir="auto">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Meridien Engine Merchant Portal" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-void-black text-on-surface antialiased min-h-screen overflow-x-hidden selection:bg-logic-teal selection:text-void-black">
        
        <!-- Toast Notification (Global) -->
        <div id="toast" class="fixed top-6 right-6 z-50 transform translate-y-10 opacity-0 pointer-events-none transition-all duration-300 bg-surface-container-high border border-logic-teal/30 text-on-surface px-5 py-3 flex items-center gap-3 shadow-[0_0_10px_rgba(194,101,42,0.1)]">
            <span id="toast-icon" class="w-2 h-2 bg-logic-teal"></span>
            <span id="toast-message" class="text-sm font-code-snippet">Notification</span>
        </div>

        <!-- Persistent Navigation Sidebar -->
        <aside class="w-[280px] bg-void-black/80 backdrop-blur-md border-r border-circuit-grey flex flex-col justify-between p-6 shrink-0 fixed h-full z-40">
            <div>
                <!-- Platform Brand & Logo -->
                <div class="flex items-center gap-3 mb-10">
                    <div class="relative w-8 h-8 flex-shrink-0 border border-logic-teal/30 rounded-lg flex items-center justify-center bg-logic-teal/5">
                        <span class="text-logic-teal font-bold text-lg">M</span>
                    </div>
                    <div>
                        <h1 class="text-lg font-bold tracking-tight text-on-surface font-heading">Meridien</h1>
                        <span class="text-[10px] uppercase tracking-wider text-on-surface-variant font-semibold">Engine Core</span>
                    </div>
                </div>

                <!-- Nav Links -->
                <nav class="space-y-1 text-sm font-medium">
                    <a href="/" class="flex items-center gap-3 px-4 py-2.5 bg-surface-container-low text-logic-teal border-l-2 border-logic-teal rounded-r-xl transition-all group">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                        Overview
                    </a>
                    <a href="/orders" class="flex items-center gap-3 px-4 py-2.5 text-on-surface-variant hover:text-logic-teal transition-all group border-l-2 border-transparent hover:border-logic-teal/50 hover:bg-surface-container-low/50 rounded-r-xl">
                        <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                        Orders
                    </a>
                    <a href="/customers" class="flex items-center gap-3 px-4 py-2.5 text-on-surface-variant hover:text-logic-teal transition-all group border-l-2 border-transparent hover:border-logic-teal/50 hover:bg-surface-container-low/50 rounded-r-xl">
                        <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                        Customers
                    </a>
                    <a href="/knowledge" class="flex items-center gap-3 px-4 py-2.5 text-on-surface-variant hover:text-logic-teal transition-all group border-l-2 border-transparent hover:border-logic-teal/50 hover:bg-surface-container-low/50 rounded-r-xl">
                        <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        Knowledge Base
                    </a>
                    <a href="/traces" class="flex items-center gap-3 px-4 py-2.5 text-on-surface-variant hover:text-logic-teal transition-all group border-l-2 border-transparent hover:border-logic-teal/50 hover:bg-surface-container-low/50 rounded-r-xl">
                        <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        System Traces
                    </a>
                    <a href="/hitl" class="flex items-center justify-between px-4 py-2.5 text-on-surface-variant hover:text-logic-teal transition-all group border-l-2 border-transparent hover:border-logic-teal/50 hover:bg-surface-container-low/50 rounded-r-xl">
                        <div class="flex items-center gap-3">
                            <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            Human Review
                        </div>
                        <span class="bg-warning-amber text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md">3</span>
                    </a>
                </nav>
            </div>
            
            <!-- Bottom Settings / User -->
            <div class="space-y-1 pt-6 border-t border-circuit-grey text-sm font-medium">
                <a href="/settings" class="flex items-center gap-3 px-4 py-2.5 text-on-surface-variant hover:text-logic-teal transition-all group border-l-2 border-transparent hover:border-logic-teal/50 hover:bg-surface-container-low/50 rounded-r-xl">
                    <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Settings
                </a>
                <div class="flex items-center gap-3 px-4 py-3 mt-4 border border-circuit-grey bg-surface-container-low hover:border-logic-teal/30 transition-colors cursor-pointer rounded-xl">
                    <div class="w-8 h-8 rounded-full bg-logic-teal/10 flex items-center justify-center text-logic-teal font-bold">A</div>
                    <div class="overflow-hidden">
                        <p class="text-xs font-semibold text-on-surface truncate">Aria S.</p>
                        <p class="text-[10px] text-on-surface-variant truncate">Administrator</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 ml-[280px] p-8 relative z-10">
            <slot />
        </main>
	</body>
</html>
