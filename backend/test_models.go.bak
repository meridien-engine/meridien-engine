package main

import (
	"context"
	"database/sql"
	"fmt"
	"log"
	"github.com/google/uuid"
	_ "github.com/lib/pq"
	"github.com/meridien-engine/meridien-engine/internal/db"
	"github.com/meridien-engine/meridien-engine/internal/domain"
	"github.com/meridien-engine/meridien-engine/internal/repository"
	"google.golang.org/genai"
)

func main() {
	connStr := "postgres://meridien:meridien@localhost:5432/meridien?sslmode=disable"
	database, _ := sql.Open("postgres", connStr)
	defer database.Close()
	var bizStr string
	database.QueryRow("SELECT id FROM businesses LIMIT 1").Scan(&bizStr)
	bizID, _ := uuid.Parse(bizStr)
	masterKey := make([]byte, 32)
	secretsRepo, _ := repository.NewSecretsRepository(db.New(database), masterKey)
	apiKey, _ := secretsRepo.GetSecret(context.Background(), bizID, domain.SecretKeyGeminiAPI)

	client, err := genai.NewClient(context.Background(), &genai.ClientConfig{APIKey: apiKey})
	if err != nil {
		log.Fatal(err)
	}

	for m, err := range client.Models.All(context.Background()) {
		if err != nil {
			log.Fatal(err)
		}
		
            fmt.Printf("Model: %s\n", m.Name)
			

	}
}
